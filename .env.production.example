# Production Environment Configuration
# Copy this file to .env for production deployment
# DO NOT commit actual secrets to version control!

# ==========================================
# Runtime Configuration
# ==========================================
PRODUCTION=1
PYTHONOPTIMIZE=1
NODE_ENV=production
RUNTIME_HEALTH_CHECK=1

# ==========================================
# OpenAI Configuration
# ==========================================
OPENAI_API_KEY=your-production-api-key-here
OPENAI_ORG_ID=

# ==========================================
# DeepSeek Configuration
# ==========================================
DEEPSEEK_API_KEY=your-production-api-key-here

# ==========================================
# API Server Configuration
# ==========================================
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=8
UVICORN_WORKERS=8

# ==========================================
# Environment
# ==========================================
ENVIRONMENT=production
LOG_LEVEL=WARNING

# ==========================================
# Security
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# CORS Configuration
CORS_ORIGINS=https://your-production-domain.com,https://app.your-domain.com

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/project_ai_prod
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ==========================================
# Redis Configuration (Optional)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================================
# Temporal Workflow Configuration
# ==========================================
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=production

# ==========================================
# Monitoring & Metrics
# ==========================================
ENABLE_METRICS=true
METRICS_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana Credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ==========================================
# Audit & Logging
# ==========================================
AUDIT_LOG_PATH=/app/logs/audit.log
LOG_DIR=/app/logs
DATA_DIR=/app/data

# ==========================================
# Email Configuration (if applicable)
# ==========================================
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# ==========================================
# Encryption Keys
# ==========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# ==========================================
# Cloud/External Services
# ==========================================
# AWS S3 (for sovereign backup)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# IPFS (for distributed storage)
IPFS_HOST=localhost
IPFS_PORT=5001

# ==========================================
# Performance Tuning
# ==========================================
# Node.js heap size (MB)
NODE_OPTIONS=--max-old-space-size=4096

# Python memory allocator
PYTHONMALLOC=malloc

# ==========================================
# Health Check Configuration
# ==========================================
HEALTHCHECK_INTERVAL=30
HEALTHCHECK_TIMEOUT=10
HEALTHCHECK_RETRIES=3

# ==========================================
# Docker Resource Limits (for docker-compose)
# ==========================================
CPU_LIMIT=2.0
MEMORY_LIMIT=2G
CPU_RESERVATION=1.0
MEMORY_RESERVATION=512M
