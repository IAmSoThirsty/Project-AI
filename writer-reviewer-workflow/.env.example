# Environment Variables for Writer-Reviewer Workflow
# DO NOT commit actual values to version control

# Azure AI Foundry Project Endpoint
# Example: https://your-project.openai.azure.com/
FOUNDRY_PROJECT_ENDPOINT=your-project-endpoint-here

# Model Deployment Name
# Example: gpt-4o, gpt-4, gpt-35-turbo
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# Note: The following variables are automatically injected by Foundry at runtime
# Do NOT set them here:
# - FOUNDRY_AGENT_NAME
# - FOUNDRY_AGENT_VERSION
# - FOUNDRY_TOOLBOX_ENDPOINT
# - PORT
# - APPLICATIONINSIGHTS_CONNECTION_STRING
