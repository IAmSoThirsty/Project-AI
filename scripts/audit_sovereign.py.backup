import os

# Configuration
ROOT_DIR = r"c:\Users\Quencher\.gemini\antigravity\scratch\sovereign-repos\Project-AI"
ARCHIVE_DIR = os.path.join(ROOT_DIR, "archive")
CURRENT_TIME = "2026-03-04 09:48"
STATUS_ACTIVE = "Active"
STATUS_OUTDATED = "Out-Dated(archive)"

# Files to ignore (git, venv, etc.)
IGNORE_DIRS = {
    ".git",
    ".venv",
    ".mypy_cache",
    ".pytest_cache",
    "__pycache__",
    "archive",
    "node_modules",
    ".hypothesis",
    ".ruff_cache",
    ".antigravity",
}
IGNORE_FILES = {"package-lock.json", "requirements.lock", ".gitignore"}


def get_header(timestamp, status, comment_char="#"):
    if comment_char == "//":
        return f"//                                           [{timestamp}]\n//                                          Productivity: {status}\n"
    elif comment_char == "<!--":
        return f"<!--                                         [{timestamp}] -->\n<!--                                        Productivity: {status} -->\n"
    else:
        return f"#                                           [{timestamp}]\n#                                          Productivity: {status}\n"


def audit_files():
    if not os.path.exists(ARCHIVE_DIR):
        os.makedirs(ARCHIVE_DIR)

    for root, dirs, files in os.walk(ROOT_DIR):
        # Skip ignored directories
        dirs[:] = [d for d in dirs if d not in IGNORE_DIRS]

        for file in files:
            if file in IGNORE_FILES:
                continue

            file_path = os.path.join(root, file)
            rel_path = os.path.relpath(file_path, ROOT_DIR)

            # Skip the script itself
            if file == "audit_sovereign.py":
                continue

            # Determine comment style based on extension
            ext = os.path.splitext(file)[1].lower()
            comment_char = "#"
            if ext in {".js", ".thirsty", ".ts", ".c", ".cpp"}:
                comment_char = "//"
            elif ext in {".html", ".xml", ".md"}:
                comment_char = "<!--"
            elif ext in {".py", ".sh", ".ps1", ".yml", ".yaml", ".toml"}:
                comment_char = "#"
            else:
                continue  # Skip unknown file types for safety

            # Audit content
            status = STATUS_ACTIVE
            outdated = False

            # Simple rules for "outdated"
            if file == "setup.py" or file == "requirements.txt" or file == "requirements.in":
                outdated = True

            try:
                with open(file_path, encoding="utf-8") as f:
                    content = f.read()

                if "DEPRECATED" in content.upper() or "LEGACY" in content.upper():
                    outdated = True

                if outdated:
                    status = STATUS_OUTDATED
                    print(f"Archiving: {rel_path}")
                    # Move to archive
                    archive_path = os.path.join(ARCHIVE_DIR, rel_path)
                    os.makedirs(os.path.dirname(archive_path), exist_ok=True)

                    # Update header before moving
                    header = get_header(CURRENT_TIME, status, comment_char)
                    if f"[{CURRENT_TIME}]" not in content and "Productivity:" not in content[:200]:
                        with open(file_path, "w", encoding="utf-8") as f:
                            f.write(header + content)

                    # Move file (overwrite if exists)
                    if os.path.exists(archive_path):
                        os.remove(archive_path)
                    os.rename(file_path, archive_path)
                else:
                    # Update header for active files
                    header = get_header(CURRENT_TIME, status, comment_char)
                    # Check if header already exists (simplistic check)
                    if f"[{CURRENT_TIME}]" not in content and "Productivity:" not in content[:200]:
                        with open(file_path, "w", encoding="utf-8") as f:
                            f.write(header + content)
                        print(f"Tagged: {rel_path}")

            except Exception as e:
                print(f"Error processing {rel_path}: {e}")


if __name__ == "__main__":
    audit_files()
