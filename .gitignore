# ============================================================
unity/**/Library/
unity/**/Temp/
unity/**/Obj/
unity/**/Build/
unity/**/Builds/
unity/**/Logs/
unity/**/MemoryCaptures/
unity/**/UserSettings/
unity/**/ProjectSettings/
