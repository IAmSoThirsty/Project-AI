# Obsidian vault team settings (shared-safe subset)
# Track shared plugin manifests + graph presets for multi-agent/collaborative docs.
# Keep workspace, personal preferences, plugin state, and cache local-only.

# Ignore everything in .obsidian by default
.obsidian/*

# Track shared plugin manifests
!.obsidian/plugins.json
!.obsidian/community-plugins.json
!.obsidian/core-plugins.json
!.obsidian/core-plugins-migration.json

# Track shared graph presets for team/agent navigation
!.obsidian/graph-colors-*.json
!.obsidian/graph-filter-*.json
!.obsidian/graph-interaction.json
!.obsidian/graph-layout.json

# Track shared templates/snippets
!.obsidian/templates/
!.obsidian/templates/**
!.obsidian/snippets/
!.obsidian/snippets/**/*.css

# Always exclude personal workspace state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace/
.obsidian/workspaces.json

# Always exclude personal preferences
.obsidian/hotkeys.json
.obsidian/appearance.json
.obsidian/config
.obsidian/app.json
.obsidian/bookmarks.json

# Always exclude cache + plugin local state
.obsidian/cache/
.obsidian/.trash/
.obsidian/plugins/
.obsidian/plugins/**
.obsidian/plugins/*/data.json
.obsidian/plugins/*/cache/

# Project-AI: re-include editor config + plugin settings (solo project, track across machines)
!.obsidian/app.json
!.obsidian/workspace.json
!.obsidian/hotkeys.json
!.obsidian/plugins/
!.obsidian/plugins/dataview/
!.obsidian/plugins/dataview/data.json
!.obsidian/plugins/templater-obsidian/
!.obsidian/plugins/templater-obsidian/data.json
