# ============================================================
# Project-AI .gitignore — Production Edition 1
# ============================================================

# ============================================================
# SECRETS & CREDENTIALS (CRITICAL — never commit these)
# ============================================================
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
secrets.json
credentials.json
secret_scan_report.json
*secret*scan*.json
*secret*scan*.txt
config/.asl3_key
src/app/users.json
.secrets.baseline

# ============================================================
# RUNTIME DATA & LOGS (generated, never committed)
# ============================================================
*.log
audit.log
out.txt
boot_log_v2.txt
logs/
audit_reports/
test_audit_sample/
test_audit_output/

# Health report snapshots and archives
data/health_snapshots/
docs/assets/health_report_*.png
governance/audit_log.yaml

# ============================================================
# ENVIRONMENTS & VIRTUAL ENVIRONMENTS
# ============================================================
.env
.env.local
.env.*.local
.env.temporal
.venv
.venv_prod/
env/
venv/
ENV/
env.bak/
venv.bak/

# ============================================================
# BYTE-COMPILED / OPTIMIZED / DLL FILES
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================
# DISTRIBUTION / PACKAGING
# ============================================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
releases/

# ============================================================
# PYINSTALLER
# ============================================================
*.manifest
*.spec

# ============================================================
# INSTALLER LOGS
# ============================================================
pip-log.txt
pip-delete-this-directory.txt

# ============================================================
# UNIT TEST / COVERAGE REPORTS
# ============================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ============================================================
# TYPE CHECKERS & LINTERS
# ============================================================
.mypy_cache/
.dmypy.json
.pyre/
.ruff_cache/

# ============================================================
# TAAR (Thirstys Active Agent Runner)
# ============================================================
.taar-cache/

# ============================================================
# IDEs & EDITORS
# ============================================================
.vscode/
.idea/
.vs/
*.swp
*.swo
*~

# ============================================================
# AGENT CONFIGURATION (generated per-environment)
# ============================================================
.agent/
.agents/

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db
*.lnk

# ============================================================
# NODE.JS
# ============================================================
node_modules/

# ============================================================
# GENERATED TEST DATA
# ============================================================
data/generated_tests/
data/global_scenarios*/cache/
data/sovereign_messages*/
data/temporal/

# ============================================================
# GRADLE & ANDROID
# ============================================================
.gradle/
!gradle/wrapper/gradle-wrapper.jar
*.iml
local.properties
*.apk
*.ap_
*.aab
*.dex
*.class
bin/
gen/
out/
captures/
.externalNativeBuild
.cxx

# ============================================================
