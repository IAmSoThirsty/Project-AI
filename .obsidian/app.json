{
  "legacyEditor": false,
  "livePreview": true,
  "defaultViewMode": "source",
  "readableLineLength": true,
  "strictLineBreaks": false,
  "showFrontmatter": true,
  "showLineNumber": true,
  "foldHeading": true,
  "foldIndent": true,
  "spellcheck": true,
  "spellcheckLanguages": ["en"],
  "useTab": true,
  "tabSize": 4,
  "autoConvertHtml": true,
  "promptDelete": false,
  "trashOption": "local",
  "attachmentFolderPath": "docs/assets",
  "newFileLocation": "root",
  "newFileFolderPath": "",
  "alwaysUpdateLinks": true,
  "userIgnoreFilters": [
    "__pycache__",
    ".git",
    "node_modules",
    ".claude",
    "*.pyc",
    "*.log"
  ],
  "pdfExportSettings": {
    "pageSize": "letter",
    "landscape": false,
    "margin": "0",
    "downscaleEmbeddedImages": true
  }
}
