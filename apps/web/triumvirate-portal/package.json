{
  "name": "@project-ai/triumvirate-portal",
  "version": "0.0.3",
  "private": true,
  "description": "The Triumvirate manifesto portal for Project-AI — three pillars: Project AI Cognitive Engine (packages/companion + packages/kernel), Cerberus Security Fortress (packages/cerberus + packages/security), Codex Deus Maximus Knowledge Repository (packages/audit + packages/canonical + packages/tarl). Runtime governance via packages/governance/triumvirate.py TriumvirateGovernor.",
  "scripts": {
    "build:css": "tailwindcss -i ./css/tailwind.css -o ./css/main.css --minify",
    "build:css:dev": "tailwindcss -i ./css/tailwind.css -o ./css/main.css",
    "watch:css": "tailwindcss -i ./css/tailwind.css -o ./css/main.css --watch",
    "dev": "tailwindcss -i ./css/tailwind.css -o ./css/main.css --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration.test.js",
    "test:lighthouse": "npx @lhci/cli autorun --config=lighthouserc.js",
    "test:watch": "jest --watch",
    "meta:generate": "node js/meta-generator.js",
    "meta:list": "node js/meta-generator.js --list",
    "validate": "jest && jest tests/integration.test.js",
    "build": "tailwindcss -i ./css/tailwind.css -o ./css/main.css --minify",
    "serve": "npx http-server -p 8080 -c-1",
    "start": "npm run serve",
    "deploy:preview": "npm run build && npm run serve",
    "audit:security": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-elevation": "^2.0.0",
    "tailwindcss-fluid-type": "^2.0.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "tailwindcss": "^3.4.0"
  }
}
