{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thirstysystems.com/schemas/authority-proof-1.0.0.json",
  "title": "Thirsty's Standard Authority Proof",
  "type": "object",
  "additionalProperties": false,
  "required": ["proof_id", "principal_id", "issued_at", "expires_at", "scope", "allowed_actions", "nonce", "signature"],
  "properties": {
    "proof_id": {"type": "string", "minLength": 1},
    "principal_id": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "allowed_actions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "nonce": {"type": "string", "minLength": 16},
    "action_id": {"type": "string"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "purpose", "value"],
      "properties": {
        "algorithm": {"const": "Ed25519"},
        "key_id": {"type": "string"},
        "purpose": {"enum": ["authority", "approval"]},
        "value": {"type": "string", "minLength": 40}
      }
    }
  }
}
