{
  "dashboard": {
    "id": null,
    "uid": "octoreflex-main",
    "title": "OctoReflex - Real-time Security Monitoring",
    "tags": ["octoreflex", "security", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Threat Score",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "octoreflex_threat_score_current",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 50,
                  "color": "yellow"
                },
                {
                  "value": 75,
                  "color": "orange"
                },
                {
                  "value": 90,
                  "color": "red"
                }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 2,
        "title": "State Transitions",
        "type": "timeseries",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(octoreflex_state_transitions_total[5m])",
            "legendFormat": "{{from_state}} → {{to_state}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Active Reflexes",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "octoreflex_active_reflexes",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "blue"
                }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Events/sec",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "octoreflex_events_per_second",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 0
          }
        }
      },
      {
        "id": 5,
        "title": "Containment Latency (p95)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(octoreflex_containment_latency_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(octoreflex_containment_latency_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(octoreflex_containment_latency_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Latency"
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2
      },
      {
        "id": 6,
        "title": "Detection Accuracy",
        "type": "piechart",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "octoreflex_true_positives_total",
            "legendFormat": "True Positives",
            "refId": "A"
          },
          {
            "expr": "octoreflex_false_positives_total",
            "legendFormat": "False Positives",
            "refId": "B"
          },
          {
            "expr": "octoreflex_false_negatives_total",
            "legendFormat": "False Negatives",
            "refId": "C"
          }
        ],
        "options": {
          "pieType": "pie",
          "displayLabels": ["name", "percent"],
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 7,
        "title": "Processing Latency Heatmap",
        "type": "heatmap",
        "gridPos": {
          "x": 18,
          "y": 8,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(octoreflex_processing_latency_seconds_bucket[5m])",
            "format": "heatmap",
            "refId": "A"
          }
        ],
        "options": {
          "calculate": true,
          "yAxis": {
            "format": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "Total Events Processed",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 8,
          "h": 6
        },
        "targets": [
          {
            "expr": "rate(octoreflex_events_processed_total[5m])",
            "legendFormat": "Events/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 9,
        "title": "False Positive Rate",
        "type": "timeseries",
        "gridPos": {
          "x": 8,
          "y": 16,
          "w": 8,
          "h": 6
        },
        "targets": [
          {
            "expr": "rate(octoreflex_false_positives_total[5m]) / (rate(octoreflex_false_positives_total[5m]) + rate(octoreflex_true_positives_total[5m])) * 100",
            "legendFormat": "False Positive Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 5,
                  "color": "yellow"
                },
                {
                  "value": 10,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "System Health",
        "type": "stat",
        "gridPos": {
          "x": 16,
          "y": 16,
          "w": 8,
          "h": 6
        },
        "targets": [
          {
            "expr": "up{job=\"octoreflex\"}",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                }
              }
            ]
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus"
        },
        {
          "name": "interval",
          "type": "interval",
          "query": "5s,10s,30s,1m,5m",
          "current": {
            "text": "5s",
            "value": "5s"
          }
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "State Transitions",
          "datasource": "Prometheus",
          "expr": "changes(octoreflex_threat_score_current[1m]) > 10",
          "tagKeys": "threat_level",
          "textFormat": "Threat level changed",
          "step": "5s"
        }
      ]
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
