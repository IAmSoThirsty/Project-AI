# Obsidian Team Vault Configuration
# -----------------------------------
# This is an EXAMPLE .gitignore for team vault scenarios.
# DO NOT rename to `.gitignore` without reading VAULT_GIT_STRATEGY.md
#
# Purpose: Selectively track shared Obsidian configurations while
#          excluding personal workspace state and cache files.
#
# Migration: See VAULT_GIT_STRATEGY.md → "Team Vault Adoption Checklist"

# ============================================================================
# OBSIDIAN: SELECTIVE TRACKING FOR TEAM VAULTS
# ============================================================================

# ----------------------------------------------------------------------------
# Track: Shared Plugin Manifests (Team-Recommended Plugins)
# ----------------------------------------------------------------------------
# These files define WHICH plugins are enabled, not their user data
!.obsidian/plugins.json                    # Community plugins enabled list
!.obsidian/community-plugins.json          # Plugin registry and versions
!.obsidian/core-plugins.json               # Core plugin toggles
!.obsidian/core-plugins-migration.json     # Plugin migration state

# ----------------------------------------------------------------------------
# Track: Shared Templates and Snippets
# ----------------------------------------------------------------------------
# Standard note templates and CSS customizations for team consistency
!.obsidian/templates/                      # Note templates directory
!.obsidian/templates/**                    # All template files
!.obsidian/snippets/                       # CSS snippets directory
!.obsidian/snippets/**/*.css               # CSS customizations

# ----------------------------------------------------------------------------
# Exclude: Personal Workspace State (ALWAYS EXCLUDE)
# ----------------------------------------------------------------------------
# These contain user-specific layouts, open files, and ephemeral state
.obsidian/workspace.json                   # Desktop workspace state
.obsidian/workspace-mobile.json            # Mobile workspace state
.obsidian/workspace/                       # Workspace cache
.obsidian/workspaces.json                  # Saved workspace layouts

# ----------------------------------------------------------------------------
# Exclude: Personal Preferences (ALWAYS EXCLUDE)
# ----------------------------------------------------------------------------
# User-specific settings that should never be shared
.obsidian/hotkeys.json                     # Personal keybindings
.obsidian/appearance.json                  # Theme, fonts, accents
.obsidian/config                           # Legacy config file

# ----------------------------------------------------------------------------
# Exclude: Cache and Ephemeral Data (ALWAYS EXCLUDE)
# ----------------------------------------------------------------------------
# Generated files that should never be committed
.obsidian/cache/                           # Metadata cache
.obsidian/plugins/**/                      # All plugin subdirectories
.obsidian/.trash/                          # Deleted file cache

# ----------------------------------------------------------------------------
# Exclude: Plugin User Data (ALWAYS EXCLUDE)
# ----------------------------------------------------------------------------
# Plugin-specific user data and state
# NOTE: We track plugins.json (which plugins), not data.json (user's data)
.obsidian/plugins/*/data.json              # Plugin-specific user settings
.obsidian/plugins/*/cache/                 # Plugin caches
.obsidian/plugins/*/*.json                 # Other plugin state files

# ----------------------------------------------------------------------------
# Conditional: Graph and Types (Use with Caution)
# ----------------------------------------------------------------------------
# These can be shared BUT may contain user-specific examples
# Uncomment to track, but expect merge conflicts if team edits concurrently

# !.obsidian/graph.json                    # Graph view defaults
# !.obsidian/types.json                    # Property type definitions

# ----------------------------------------------------------------------------
# Exclude: Bookmarks (ALWAYS EXCLUDE)
# ----------------------------------------------------------------------------
# User's personal bookmarks to notes
.obsidian/bookmarks.json

# ----------------------------------------------------------------------------
# Exclude: App Settings (HIGH CONFLICT RISK)
# ----------------------------------------------------------------------------
# Contains mixed personal/shared settings with machine-specific paths
.obsidian/app.json                         # App-level settings

# ============================================================================
# STANDARD GITIGNORE (from main .gitignore)
# ============================================================================

