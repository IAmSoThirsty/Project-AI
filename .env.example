# Project-AI Environment Configuration
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# ==========================================
# OpenAI Configuration
# ==========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Organization ID
OPENAI_ORG_ID=

# ==========================================
# DeepSeek Configuration
# ==========================================
# Get your API key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ==========================================
# API Server Configuration
# ==========================================
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4

# Development/Production mode
ENVIRONMENT=development

# ==========================================
# TARL Configuration
# ==========================================
TARL_VERSION=1.0

# ==========================================
# Audit & Logging
# ==========================================
AUDIT_LOG_PATH=audit.log
LOG_LEVEL=INFO

# ==========================================
# Security
# ==========================================
# Generate a secure random secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ==========================================
# Database (if applicable)
# ==========================================
DATABASE_URL=

# ==========================================
# Temporal Workflow Configuration
# ==========================================
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ==========================================
# Cloud/External Services (Optional)
# ==========================================
# Add any additional API keys or service credentials here

# ==========================================
# MCP / Wiki Tasks Integration
# ==========================================
# Port used by local Obsidian/wiki-tasks MCP endpoint
WIKI_TASKS_MCP_PORT=7777

# Bearer token used by mcp.json for the local wiki-tasks MCP server
WIKI_TASKS_BEARER_TOKEN=

# ==========================================
# Legion LLM Configuration
# ==========================================
# Provider: "groq" (free API, recommended) or "ollama" (local, no cost)
LEGION_LLM_PROVIDER=groq

# Groq — free account at console.groq.com, no credit card required
# Default model: llama-3.3-70b-versatile (fast, capable, free tier)
GROQ_API_KEY=

# Optional: override the model for whichever provider you choose
# Groq options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# Ollama options: qwen3:8b, qwen3:14b, llama3.2:3b
LEGION_MODEL=

# Ollama — only needed if LEGION_LLM_PROVIDER=ollama
# Default points to local Ollama install
OLLAMA_BASE_URL=http://localhost:11434/v1
