# Project-AI development stack environment.
# Copy values into your shell or a local .env file before running Compose.
# Do not commit real credentials.

# Optional for public routes. Required for protected API routes:
# GET /audit
# POST /chimera/verdict
# POST /chimera/canary
# POST /atlas/sludge
PROJECT_AI_API_TOKEN=

# CLI endpoint. The local Compose gateway binds to 127.0.0.1:8000.
PROJECT_AI_API_URL=http://127.0.0.1:8000

# Desktop smoke mode used by CI and local offscreen validation.
PROJECT_AI_DESKTOP_SMOKE=1
QT_QPA_PLATFORM=offscreen
