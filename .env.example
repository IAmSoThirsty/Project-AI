# Project-AI development environment
# Copy to .env and fill in values before running Compose.
# Never commit .env with real credentials.

# ── API ────────────────────────────────────────────────────────────────────
# Public local-instance label shown before authentication. This is presentation
# identity only; it is not a credential, machine identity, or authority grant.
PROJECT_AI_INSTANCE_NAME=PROJECT-AI-LOCAL
PROJECT_AI_TAAR_REPO_ROOT=
# Required for protected routes: GET /audit, POST /chimera/verdict,
# POST /chimera/canary, POST /atlas/sludge
# Leave empty to allow unauthenticated access to public routes.
PROJECT_AI_API_TOKEN=
PROJECT_AI_MACHINE_CREDENTIALS_REQUIRED=false

# Required for first-run Owner creation. Generate a long random value, use it once,
# then remove it after bootstrap has closed.
PROJECT_AI_SETUP_SECRET=

# Required before TOTP enrollment. Generate with:
# uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROJECT_AI_MFA_KEY=
# Compose-only local PostgreSQL password. Replace it even on private development hosts.
PROJECT_AI_POSTGRES_PASSWORD=
# Direct API deployments use a full PostgreSQL DSN. Compose constructs this internally.
PROJECT_AI_DATABASE_URL=
# Server-only signing secret for one-use execution capabilities. Minimum 32 UTF-8 bytes.
# Never expose this value through Vite or any browser-readable environment variable.
PROJECT_AI_EXECUTION_SECRET=
# Optional copied Waterfall runtime activation. Leave false until the target
# cluster has rotated V3Q authority and approved the Waterfall target/config.
PROJECT_AI_WATERFALL_ENABLED=false
PROJECT_AI_WATERFALL_CONFIG=
# Optional direct-deployment override for SWR export bundles. The directory must be
# writable by the API service account. Compose and Helm use /data/swr-bundles.
PROJECT_AI_SWR_BUNDLE_DIR=
# Local Compose only: trust loopback X-Forwarded-For from the private Nginx network.
PROJECT_AI_BOOTSTRAP_TRUST_PRIVATE_PROXY=false

# Thirsty's Standard V3 + Q remains dormant in development by default. Production
# sets REQUIRED=true and loads only an owner-controlled, rotated public-key registry;
# private owner keys stay offline and outside the API runtime.
THIRSTYS_V3Q_REQUIRED=false
# Optional public-key registry path. Owner private keys must remain outside the runtime.
THIRSTYS_V3Q_REGISTRY=
THIRSTYS_V3Q_OP_MAP=

# ── CLI / tooling ──────────────────────────────────────────────────────────
# The local Compose gateway binds to 127.0.0.1:8000
PROJECT_AI_API_URL=http://127.0.0.1:8000

# ── MCP stdio server (optional; packages/mcp_server) ──────────────────────
# Gateway the MCP bridge forwards tool calls to.
PROJECT_AI_MCP_API_URL=http://127.0.0.1:8000
# Only needed for the machine-bearer tools (audit query, verdict relay,
# sludge generate/list); public tools work without it.
PROJECT_AI_MCP_TOKEN=

# ── Desktop ────────────────────────────────────────────────────────────────
# Enables headless/offscreen mode used by CI and local smoke validation
PROJECT_AI_DESKTOP_SMOKE=1
QT_QPA_PLATFORM=offscreen

# ── Compose service routing ────────────────────────────────────────────────
# Passed to service containers to select which service module to run.
# Values: swr | atlas | arbiter-rlp  (set automatically by compose.yaml)
# PROJECT_AI_SERVICE=swr

# ── Audit ──────────────────────────────────────────────────────────────────
# Path inside the api container where the audit JSONL log is written.
# Mapped to the audit-data volume. Override only for non-standard setups.
# PROJECT_AI_AUDIT_PATH=/data/chimera-audit.jsonl

# ── Ports (reference — matches docs/PORT_LEDGER.md) ───────────────────────
# API:          http://127.0.0.1:8000
# Docs portal:  http://127.0.0.1:4173
# Proof portal: http://127.0.0.1:4174
# Control Center: http://127.0.0.1:4175
# Internal:     genesis :8080 | swr/atlas/arbiter-rlp :8000 (not published)
