# ⚖️ Project-AI: Sovereign Environment Configuration Template
# Copy this file to .env and fill in your actual API keys.
# DO NOT commit .env to version control! Enforced by .gitignore.

# ─────────────────────────────────────────────
# 🏗️ Core Substrate & API
# ─────────────────────────────────────────────
# The logical host for the API server (0.0.0.0 for containerized/external)
API_HOST=0.0.0.0
# Port for the Sovereign Interface
API_PORT=8001
# Worker count for logic propagation (Scaled by CPU density)
API_WORKERS=4
# Execution Environment: [development | staging | production]
ENVIRONMENT=development

# ─────────────────────────────────────────────
# 🛡️ Security / PSIA / OctoReflex
# ─────────────────────────────────────────────
# Sovereign Secret Key (Used for JWT and internal encryption)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# CORS Origins (Comma-separated whitelist)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ─────────────────────────────────────────────
# 🤖 Neural Models / AGI Sandboxing
# ─────────────────────────────────────────────
# OpenAI API Key (Required for Codex Deus logic)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# DeepSeek API Key (Required for high-efficiency logic)
DEEPSEEK_API_KEY=

# ─────────────────────────────────────────────
# ⚖️ Governance & Audit (TARL)
# ─────────────────────────────────────────────
# The version of Thirsty-Lang/TARL being enforced
TARL_VERSION=2.1
# Path for the local Accountability Ledger (Audit Log)
AUDIT_LOG_PATH=governance/audit.log
# Logging granularity: [DEBUG | INFO | WARNING | ERROR | CRITICAL]
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# 📦 Infrastructure & Workflows
# ─────────────────────────────────────────────
# Connection string for the backing datastore (if applicable)
DATABASE_URL=

# Temporal Workflow Orchestration
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ─────────────────────────────────────────────
# 🌌 Sovereign Extensions
# ─────────────────────────────────────────────
# Placeholder for project-specific variables (Planetary Defense, etc.)
SOVEREIGN_MODE_ACTIVE=true
