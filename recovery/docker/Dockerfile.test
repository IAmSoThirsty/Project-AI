# (Substrate Validation Blueprint)         [2026-04-09 05:25]
#                                          Status: Active
# Multi-stage build for test suite

# Build arguments for reproducibility
ARG SOURCE_COMMIT_SHA="unknown"
ARG BUILD_VERSION="dev"
ARG SOURCE_DATE_EPOCH="0"
ARG BUILD_TIMESTAMP="unknown"

# Stage 1: Build dependencies
FROM python:3.11-slim@sha256:0b23cfb7425d065008b778022a17b1551c82f8b4866ee5a7a200084b7e2eafbf AS builder

WORKDIR /build

# Install build dependencies (includes test suite requirements)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    gfortran \
    make \
    pkg-config \
    libssl-dev \
    libffi-dev \
    libpq-dev \
    libjpeg-dev \
    zlib1g-dev \
    libtiff-dev \
    libfreetype6-dev \
    liblcms2-dev \
    libwebp-dev \
    libopenblas-dev \
    liblapack-dev \
    && rm -rf /var/lib/apt/lists/*

# Build wheels for all dependencies
COPY requirements.txt requirements-dev.txt requirements-test.txt /tmp/
RUN pip wheel --no-cache-dir --no-deps --wheel-dir /build/wheels \
    -r /tmp/requirements.txt \
    -r /tmp/requirements-dev.txt \
    -r /tmp/requirements-test.txt

# Stage 2: Test runtime
FROM python:3.11-slim@sha256:0b23cfb7425d065008b778022a17b1551c82f8b4866ee5a7a200084b7e2eafbf

# OCI labels for reproducibility
LABEL org.opencontainers.image.revision="${SOURCE_COMMIT_SHA}"
LABEL org.opencontainers.image.version="${BUILD_VERSION}"
LABEL org.opencontainers.image.created="${BUILD_TIMESTAMP}"
LABEL org.opencontainers.image.source="https://github.com/IAmSoThirsty/Sovereign-Governance-Substrate"
LABEL org.opencontainers.image.title="Project-AI Test Suite"
LABEL org.opencontainers.image.description="Test and validation environment"

# Create non-root user for security
RUN groupadd -r testrunner && useradd -r -g testrunner testrunner

WORKDIR /app

# Install runtime dependencies (includes test suite requirements)
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core libraries
    libssl3 \
    libffi8 \
    libpq5 \
    # Image processing
    libjpeg62 \
    zlib1g \
    libtiff5 \
    libfreetype6 \
    liblcms2-2 \
    libwebp7 \
    # Scientific computing
    libopenblas0 \
    liblapack3 \
    libgomp1 \
    # OpenCV dependencies (for opencv-python-headless)
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgstreamer1.0-0 \
    # Audio/Video processing (for whisper, pydub tests)
    ffmpeg \
    # Utilities
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src:/app
ENV SOURCE_DATE_EPOCH=${SOURCE_DATE_EPOCH}

# Copy wheels from builder and install
COPY --from=builder /build/wheels /wheels
COPY requirements.txt requirements-dev.txt requirements-test.txt /tmp/
RUN python -m pip install --no-cache-dir --upgrade pip@sha256:0e85a6662e08e64c2d3ef0e40552b412953289069d5843b006cb5561a0d78314 \
    && python -m pip install --no-cache-dir /wheels/* \
    && rm -rf /wheels

COPY --chown=testrunner:testrunner . /app

USER testrunner

CMD ["python", "Verify-SovereignLoaders.py"]
