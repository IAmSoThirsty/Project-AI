name: Thirty's Monolith (Schematic Focus)

on:
  push:
    branches: [ "**" ]
  pull_request:
    branches: [ "**" ]
  workflow_dispatch:

permissions:
  contents: write
  security-events: write
  statuses: write
  checks: write

jobs:
  enforce-schematics:
    name: "🤖 Schematic Guardian"
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          ref: ${{ github.head_ref }}
          fetch-depth: 0

      - name: Update submodules
        run: git submodule update --init --recursive

      - name: Set up Python
        uses: actions/setup-python@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          python-version: '3.11'

      - name: Run Schematic Guardian
        run: |
          python -c "
          import sys, os
          sys.path.append(os.getcwd())
          try:
              from src.app.agents.codex_deus_maximus import create_codex
              print('🤖 Guardian is auditing schematics...')
              agent = create_codex()
              report = agent.run_schematic_enforcement()
              print('✅ Audit Report:', report)
              if report['structure_check']['status'] == 'BROKEN':
                  print('❌ Critical Schematic Violation detected.')
                  sys.exit(1)
          except ImportError:
              print('⚠️ Agent not found. Skipping enforcement.')
          except Exception as e:
              print(f'❌ Agent Failure: {e}')
              sys.exit(1)
          "

      - name: Commit Fixes
        uses: stefanzweifel/git-auto-commit-action@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          commit_message: "🤖 Schematic Guardian: Enforced standards"
          file_pattern: "."

  verify-integrity:
    name: "🛡️ Verify Integrity"
    needs: enforce-schematics
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@0c366fd6a839edf440554fa01a7085ccba70ac98

      - name: Update submodules
        run: git submodule update --init --recursive
      
      - name: Initialize CodeQL
        uses: github/codeql-action/init@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          languages: python, javascript
      - name: Autobuild
        uses: github/codeql-action/autobuild@0c366fd6a839edf440554fa01a7085ccba70ac98
      - name: Run CodeQL
        uses: github/codeql-action/analyze@0c366fd6a839edf440554fa01a7085ccba70ac98

      - name: Pip Audit
        run: |
          pip install pip-audit
          pip-audit --format json -o pip_audit_report.json || true

  validate-functions:
    name: "🏗️ Validate Functions"
    needs: enforce-schematics
    runs-on: ubuntu-latest
    strategy:
      matrix:
        language: [python, node, android]
    steps:
      - uses: actions/checkout@0c366fd6a839edf440554fa01a7085ccba70ac98

      - name: Update submodules
        run: git submodule update --init --recursive

      - name: Python Tests
        if: matrix.language == 'python'
        uses: actions/setup-python@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          python-version: '3.11'
      - run: |
          if [ "${{ matrix.language }}" == "python" ]; then
            pip install pytest pytest-cov
            if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
            pytest --cov=src -q
          fi

      - name: Node Build
        if: matrix.language == 'node'
        uses: actions/setup-node@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          node-version: '18.x'
      - run: |
          if [ "${{ matrix.language }}" == "node" ]; then
            npm install
            npm run build --if-present
            npm test || true
          fi

      - name: Android Build
        if: matrix.language == 'android'
        uses: actions/setup-java@0c366fd6a839edf440554fa01a7085ccba70ac98
        with:
          java-version: '11'
          distribution: 'temurin'
      - run: |
          if [ "${{ matrix.language }}" == "android" ]; then
            cd android
            chmod +x gradlew
            ./gradlew build
          fi
