# Cerberus Configuration
# Copy this file to .env and adjust values as needed

# Guardian Spawn Settings
CERBERUS_SPAWN_FACTOR=3                  # Number of guardians spawned per bypass (1-10)
CERBERUS_MAX_GUARDIANS=27                # Maximum guardians before shutdown (1-1000)
CERBERUS_SPAWN_COOLDOWN_SECONDS=1.0      # Minimum seconds between spawns (0-60)
CERBERUS_SPAWN_RATE_PER_MINUTE=60        # Maximum spawn events per minute (1-1000)

# Rate Limiting Settings
CERBERUS_PER_SOURCE_RATE_LIMIT_PER_MINUTE=30  # Max bypass attempts per source/minute (1-1000)
CERBERUS_RATE_LIMIT_CLEANUP_INTERVAL_SECONDS=300  # Cleanup interval for rate limits (60-3600)

# Logging Settings
CERBERUS_LOG_JSON=true                   # Enable structured JSON logging
CERBERUS_LOG_LEVEL=INFO                  # Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)

# Security Features
CERBERUS_ENABLE_AUDIT_LOGGING=true       # Enable audit logging
CERBERUS_ENABLE_METRICS=true             # Enable metrics collection

