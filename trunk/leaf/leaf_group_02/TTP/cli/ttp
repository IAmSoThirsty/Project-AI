@cli.command()
@click.option("--api-url", help="API base URL")
def config(api_url: Optional[str]):
    """Configure CLI settings."""
    current_config = load_config()

    if api_url:
        current_config["api_url"] = api_url
        save_config(current_config)
        console.print(f"[green]✓ API URL set to: {api_url}[/green]")
    else:
        # Show current configuration
        console.print(Panel(
            f"API URL: {current_config.get('api_url', DEFAULT_API_URL)}\n"
            f"Authenticated: {'Yes' if current_config.get('token') else 'No'}",
            title="Current Configuration",
            border_style="cyan"
        ))


if __name__ == "__main__":
    cli()
