# TTP API Environment Configuration
# Copy to .env and fill in your values

# Application
DEBUG=false
ENABLE_DOCS=true

# Database
DATABASE_URL=postgresql://ttp:password@localhost:5432/ttp

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32

# S3 Storage
S3_BUCKET=ttp-texture-assets
S3_REGION=us-east-1

# CORS
CORS_ORIGINS=http://localhost:3000,https://ttp.example.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
