{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://project-ai.dev/schemas/metadata.schema.json",
  "title": "Project-AI Metadata Schema",
  "description": "JSON Schema for YAML frontmatter in Markdown docs. Rebuilt 2026-06-10 from a survey of the actual corpus (1,314 files with frontmatter, 617 distinct fields): constraints are kept only where the corpus conforms; free-form fields are documented without constraints.",
  "version": "1.0.0",
  "type": "object",
  "required": [],
  "properties": {
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Brief description of the document's purpose and scope",
      "pattern": "^[A-Z].*[^.]$",
      "examples": [
        "Configuration for AI behavior when interacting with Codacy's MCP Server",
        "Comprehensive guide for implementing metadata validation systems"
      ]
    },
    "applyTo": {
      "type": "string",
      "description": "Glob pattern specifying which files this metadata applies to",
      "pattern": "^[\\w\\-\\.\\*/]+$",
      "default": "**",
      "examples": [
        "**",
        "**/*.md",
        "src/**/*.py",
        "docs/**"
      ]
    },
    "version": {
      "description": "Document version; semver string preferred, numeric accepted"
    },
    "lastUpdated": {
      "type": "string",
      "description": "ISO 8601 date of last update (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "format": "date",
      "examples": [
        "2026-01-23",
        "2025-12-31"
      ]
    },
    "status": {
      "description": "Document lifecycle state (free-form; common: current, active, archived, published, production, complete)"
    },
    "category": {
      "description": "Document category (free-form)"
    },
    "tags": {
      "description": "Topic tags; list preferred"
    },
    "author": {
      "description": "Author; string or structured mapping"
    },
    "reviewers": {
      "type": "array",
      "description": "List of reviewers who approved this document",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      },
      "uniqueItems": true,
      "maxItems": 10
    },
    "relatedDocs": {
      "type": "array",
      "description": "Related documentation files (relative paths)",
      "items": {
        "type": "string",
        "pattern": "^[\\w\\-\\./ ]+\\.(md|txt|pdf|json|yaml|yml)$"
      },
      "uniqueItems": true,
      "maxItems": 20
    },
    "dependencies": {
      "type": "array",
      "description": "External dependencies or prerequisites",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 200
      },
      "uniqueItems": true,
      "maxItems": 30
    },
    "audience": {
      "description": "Intended audience; string or list"
    },
    "confidentiality": {
      "type": "string",
      "description": "Confidentiality classification",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "default": "public"
    },
    "priority": {
      "description": "Document priority (free-form; common: canonical, supporting, p0-p3, high/medium/low)"
    },
    "compliance": {
      "type": "array",
      "description": "Compliance frameworks this document addresses",
      "items": {
        "type": "string",
        "enum": [
          "SOC2",
          "ISO27001",
          "GDPR",
          "HIPAA",
          "PCI-DSS",
          "NIST",
          "CIS",
          "OWASP"
        ]
      },
      "uniqueItems": true
    },
    "reviewSchedule": {
      "type": "string",
      "description": "How often this document should be reviewed",
      "enum": [
        "weekly",
        "monthly",
        "quarterly",
        "biannually",
        "annually",
        "ad-hoc"
      ],
      "default": "quarterly"
    },
    "expiryDate": {
      "type": "string",
      "description": "ISO 8601 date when document expires",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "format": "date"
    },
    "language": {
      "description": "Language of the document or subject programming language (free-form; corpus uses both ISO codes and programming language names)"
    },
    "license": {
      "type": "string",
      "description": "License identifier (SPDX format)",
      "pattern": "^[A-Za-z0-9.-]+$",
      "examples": [
        "MIT",
        "Apache-2.0",
        "GPL-3.0",
        "CC-BY-4.0"
      ]
    },
    "customFields": {
      "type": "object",
      "description": "Project-specific custom metadata fields",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "maxProperties": 20
    },
    "title": {
      "description": "Corpus convention field: title"
    },
    "id": {
      "description": "Corpus convention field: id"
    },
    "type": {
      "description": "Corpus convention field: type"
    },
    "created": {
      "description": "Corpus convention field: created"
    },
    "last_verified": {
      "description": "Corpus convention field: last_verified"
    },
    "created_date": {
      "description": "Corpus convention field: created_date"
    },
    "updated_date": {
      "description": "Corpus convention field: updated_date"
    },
    "archived_date": {
      "description": "Corpus convention field: archived_date"
    },
    "stakeholders": {
      "description": "Corpus convention field: stakeholders"
    },
    "related_systems": {
      "description": "Corpus convention field: related_systems"
    },
    "review_cycle": {
      "description": "Corpus convention field: review_cycle"
    },
    "test_type": {
      "description": "Corpus convention field: test_type"
    },
    "test_id": {
      "description": "Corpus convention field: test_id"
    },
    "coverage_target": {
      "description": "Corpus convention field: coverage_target"
    },
    "automation_status": {
      "description": "Corpus convention field: automation_status"
    },
    "related_docs": {
      "description": "Corpus convention field: related_docs"
    },
    "layer": {
      "description": "Corpus convention field: layer"
    },
    "area": {
      "description": "Corpus convention field: area"
    },
    "archive_reason": {
      "description": "Corpus convention field: archive_reason"
    },
    "historical_value": {
      "description": "Corpus convention field: historical_value"
    },
    "restore_candidate": {
      "description": "Corpus convention field: restore_candidate"
    },
    "path_confirmed": {
      "description": "Corpus convention field: path_confirmed"
    },
    "prerequisites": {
      "description": "Corpus convention field: prerequisites"
    },
    "classification": {
      "description": "Corpus convention field: classification"
    },
    "aliases": {
      "description": "Corpus convention field: aliases"
    },
    "agent": {
      "description": "Corpus convention field: agent"
    },
    "module": {
      "description": "Corpus convention field: module"
    },
    "platform": {
      "description": "Corpus convention field: platform"
    },
    "complexity_level": {
      "description": "Corpus convention field: complexity_level"
    },
    "demonstrates": {
      "description": "Corpus convention field: demonstrates"
    },
    "runnable": {
      "description": "Corpus convention field: runnable"
    },
    "estimated_completion": {
      "description": "Corpus convention field: estimated_completion"
    },
    "requires": {
      "description": "Corpus convention field: requires"
    },
    "template_type": {
      "description": "Corpus convention field: template_type"
    },
    "template_status": {
      "description": "Corpus convention field: template_status"
    },
    "date": {
      "description": "Corpus convention field: date"
    },
    "day": {
      "description": "Corpus convention field: day"
    },
    "week": {
      "description": "Corpus convention field: week"
    },
    "adr_status": {
      "description": "Corpus convention field: adr_status"
    },
    "accuracy_rating": {
      "description": "Corpus convention field: accuracy_rating"
    },
    "api_reference": {
      "description": "Corpus convention field: api_reference"
    },
    "architecture_layer": {
      "description": "Corpus convention field: architecture_layer"
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "description": "Comprehensive metadata validation system for Project-AI documentation",
      "version": "1.0.0",
      "lastUpdated": "2026-01-23",
      "status": "ACTIVE",
      "category": "documentation",
      "tags": [
        "metadata",
        "validation",
        "json-schema",
        "powershell"
      ],
      "author": "AGENT-018",
      "audience": "developers",
      "confidentiality": "public",
      "priority": "high",
      "reviewSchedule": "quarterly",
      "language": "en"
    },
    {
      "description": "Configuration for AI behavior when interacting with Codacy's MCP Server",
      "applyTo": "**",
      "status": "ACTIVE",
      "category": "configuration",
      "tags": [
        "codacy",
        "mcp",
        "ai-configuration"
      ],
      "audience": "developers"
    }
  ]
}