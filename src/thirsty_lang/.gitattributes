# Thirsty-lang Module — GitHub Linguist Configuration
# Official language recognition for GitHub
#                                           [2026-03-04 12:45]
#                                          Productivity: Active
#
# UNIVERSAL THIRSTY FAMILY (UTF):
#   1. Thirsty-Lang       — Main Language
#   2. Thirst of Gods     — Higher Functions
#   3. T.A.R.L.           — Defensive Programming Language
#   4. Shadow Thirst      — Dual Plane
#   5. TSCG               — Thirsty's Symbolic Compression Grammar
#   6. TSCG-B             — TSCG (Binary)

# 1. Thirsty-Lang (Main)
*.thirsty linguist-language=Thirsty-lang linguist-detectable

# 2. Thirst of Gods
*.thirstofgods linguist-language=Thirsty-lang linguist-detectable
*.tog linguist-language=Thirsty-lang linguist-detectable

# 3. T.A.R.L.
*.tarl linguist-language=Thirsty-lang linguist-detectable

# 4. Shadow Thirst
*.shadow linguist-language=Thirsty-lang linguist-detectable

# 5. TSCG
*.tscg linguist-language=Thirsty-lang linguist-detectable

# 6. TSCG-B
*.tscgb linguist-language=Thirsty-lang linguist-detectable

# Example files should be counted in language statistics
examples/** linguist-vendored=false
examples/**/*.thirsty linguist-language=Thirsty-lang

# JavaScript implementation files
src/*.js linguist-vendored=false

# Python implementation files
src/*.py linguist-vendored=false

# Security and test files (include in stats)
src/security/** linguist-vendored=false
src/test/** linguist-vendored=false

# Documentation
*.md linguist-documentation
docs/** linguist-documentation

# Playground files (vendored)
playground/** linguist-vendored

# VS Code extension (vendored, not part of core language)
vscode-extension/** linguist-vendored

# Dependencies (vendored)
node_modules/** linguist-vendored
.venv/** linguist-vendored
__pycache__/** linguist-vendored
*.pyc linguist-vendored

# Build artifacts (vendored)
dist/** linguist-vendored
build/** linguist-vendored

# Configuration files (not vendored, but not documentation)
*.json -linguist-documentation
*.toml -linguist-documentation
package.json -linguist-documentation
requirements.txt -linguist-documentation
