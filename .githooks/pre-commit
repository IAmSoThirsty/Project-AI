#!/usr/bin/env python3

"""Git pre-commit hook for repository policy checks."""

from __future__ import annotations

import shutil
import subprocess
import sys


def resolve_python_command() -> list[str]:
    """Resolve an available Python launcher command."""
    if shutil.which("py"):
        return ["py", "-3"]
    if shutil.which("python3"):
        return ["python3"]
    if shutil.which("python"):
        return ["python"]

    raise RuntimeError(
        "No Python runtime found for pre-commit checks. "
        "Install Python or ensure 'py', 'python3', or 'python' is on PATH."
    )


def run_check(python_command: list[str], script: str) -> int:
    """Run a repository check script with the selected Python launcher."""
    command = [*python_command, script]
    result = subprocess.run(command, check=False)
    return result.returncode


def main() -> int:
    """Execute mandatory pre-commit checks."""
    try:
        python_command = resolve_python_command()
    except RuntimeError as error:
        print(f"ERROR: {error}", file=sys.stderr)
        return 127

    scripts = [
        "tools/check_large_files_for_lfs.py",
        "tools/enforce_vault_write_scope.py",
        "tools/validate_mandatory_agent_protocol.py",
    ]
    for script in scripts:
        exit_code = run_check(python_command, script)
        if exit_code != 0:
            return exit_code

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
