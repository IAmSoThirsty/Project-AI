# ── Storm Desk Environment ──────────────────────────────────────────
# Copy to .env and fill in real values.  Never commit .env to VCS.

# News API keys
NEWSDATA_API_KEY=
MEDIASTACK_API_KEY=
GNEWS_API_KEY=

# RSS feeds (comma-separated URLs)
RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://www.aljazeera.com/xml/rss/all.xml

# Polling
POLL_INTERVAL_SECONDS=20

# Auto-escalation thresholds
AUTO_TRIGGER_MIN_SCORE=72
AUTO_TRIGGER_MIN_SOURCES=2
AUTO_TRIGGER_REQUIRE_WIRE=false

# Ports
DESKTOP_PORT=4318
EVENT_WORKER_PORT=4319

# Storage
STORE_PATH=./data/incidents.db
STORE_MAX_AGE_DAYS=90

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
