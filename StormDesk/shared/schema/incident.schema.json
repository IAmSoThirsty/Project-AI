{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storm-desk.local/schema/incident.schema.json",
  "title": "Incident",
  "description": "Canonical incident record produced by the Storm Desk event pipeline.",
  "type": "object",
  "required": ["id", "headline", "sources", "score", "status", "first_seen_at"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique incident identifier (UUIDv4)."
    },
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Short headline describing the incident."
    },
    "summary": {
      "type": "string",
      "maxLength": 4096,
      "description": "Longer narrative description of the incident."
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "maxLength": 64 },
      "description": "Extracted high-impact keywords present in the incident text."
    },
    "regions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "ISO country codes or region names associated with the incident."
    },
    "source_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of distinct sources reporting this incident."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url", "published_at"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "published_at": { "type": "string", "format": "date-time" },
          "title": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Individual source articles clustered into this incident."
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Pipeline-computed severity score (0–100)."
    },
    "status": {
      "type": "string",
      "enum": ["watch", "elevated", "major"],
      "description": "Current escalation status derived from score and verification."
    },
    "verification": {
      "type": "object",
      "required": ["independent_sources", "wire_confirmed", "broadcaster_confirmed"],
      "properties": {
        "independent_sources": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of unique independent sources."
        },
        "wire_confirmed": {
          "type": "boolean",
          "description": "Whether a major wire service (Reuters/AP/AFP) has confirmed."
        },
        "broadcaster_confirmed": {
          "type": "boolean",
          "description": "Whether a major broadcaster has confirmed."
        }
      },
      "additionalProperties": false
    },
    "first_seen_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the incident was first detected."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the most recent cluster update."
    }
  },
  "additionalProperties": false
}
