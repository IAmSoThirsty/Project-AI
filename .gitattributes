# (Substrate Attribute Vector)               [2026-04-09 04:26]
#                                          Status: Active

# Auto detect text files and perform LF normalization
* text=auto

# ───────────────────────────────────────────────────────────
# Git LFS tracking for AI model & artifact files
# ───────────────────────────────────────────────────────────
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
*.npy filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text

# ═══════════════════════════════════════════════════════════
# UNIVERSAL THIRSTY FAMILY (UTF) — Language Recognition
# ═══════════════════════════════════════════════════════════
#   1. Thirsty-Lang       — Main Language
#   2. Thirst of Gods     — Higher Functions
#   3. T.A.R.L.           — Defensive Programming Language
#   4. Shadow Thirst      — Dual Plane
#   5. TSCG               — Thirsty's Symbolic Compression Grammar
#   6. TSCG-B             — TSCG (Binary)

# 1. Thirsty-Lang (Main)
*.thirsty linguist-language=Thirsty-lang linguist-detectable

# 2. Thirst of Gods (Higher Functions)
*.thirstofgods linguist-language=Thirsty-lang linguist-detectable
*.tog linguist-language=Thirsty-lang linguist-detectable

# 3. T.A.R.L. (Defensive Programming)
*.tarl linguist-language=Thirsty-lang linguist-detectable

# 4. Shadow Thirst (Dual Plane)
*.shadow linguist-language=Thirsty-lang linguist-detectable

# 5. TSCG (Symbolic Compression Grammar)
*.tscg linguist-language=Thirsty-lang linguist-detectable

# 6. TSCG-B (Binary)
*.tscgb linguist-language=Thirsty-lang linguist-detectable

# ───────────────────────────────────────────────────────────
# Ensure language samples count in statistics
# ───────────────────────────────────────────────────────────
src/thirsty_lang/examples/** linguist-vendored=false
src/thirsty_lang/playground/** linguist-vendored=false
examples/** linguist-vendored=false
linguist-submission/samples/** linguist-vendored=false

# ───────────────────────────────────────────────────────────
