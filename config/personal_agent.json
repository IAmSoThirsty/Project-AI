{
  "backend": "openai_compatible",
  "base_url": "http://localhost:1234/v1",
  "model": "local-model",
  "temperature": 0.7,
  "max_tokens": 700,
  "instructions_file": "config/personal_agent_instructions.md",
  "profile_file": "data/personal_agent/profile.json",
  "notes_file": "data/personal_agent/notes.md",
  "event_log_file": "data/personal_agent/events.jsonl",
  "training_export_file": "data/personal_agent/training/chat_export.jsonl",
  "obsidian_vault_path": "wiki",
  "scribe_folder": "_Scribe/Project-AI",
  "repo_root": ".",
  "scan_exclude_dirs": [
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    ".venv_airllm",
    ".venv_prod",
    "__pycache__",
    "build",
    "dist",
    "htmlcov",
    "node_modules",
    "venv"
  ],
  "max_text_preview_chars": 12000,
  "hash_limit_mb": 25
}
