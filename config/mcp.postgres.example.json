{
  "mcpServers": {
    "postgres-readonly": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${POSTGRES_URL}"
      ],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      },
      "description": "Example MCP server for PostgreSQL read-focused workflows"
    }
  }
}
