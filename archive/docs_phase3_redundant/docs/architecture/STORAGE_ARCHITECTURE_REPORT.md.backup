# File: k8s/base/storage-classes.yaml (UPDATE)
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: fast-ssd-regional
parameters:
  type: pd-ssd
  provisioned-iops-on-create: "3000"  # ADD
